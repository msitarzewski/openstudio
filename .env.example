# OpenStudio Development Configuration

# Development Mode
# - docker: Run all services in Docker (recommended for most users)
# - local: Run signaling server locally with hot reload (for core development)
DEV_MODE=docker

# Local Development Port (only used when DEV_MODE=local)
# Note: Docker mode always uses port 6736
LOCAL_SIGNALING_PORT=6736

# Icecast credentials
ICECAST_SOURCE_PASSWORD=changeme
ICECAST_ADMIN_PASSWORD=changeme
ICECAST_ADMIN_USERNAME=admin
ICECAST_RELAY_PASSWORD=changeme

# TURN server
COTURN_PASSWORD=changeme

# Icecast connection (server-side)
#
# ICECAST_HOST / ICECAST_PORT tell the signaling server where to reach Icecast
# for two things: (a) streaming source connection, (b) the public /stream/*
# listener proxy. They must point to wherever Icecast actually listens.
#
#   - docker-compose dev: localhost:6737 (default — Icecast container maps to 6737)
#   - system Icecast (apt install icecast2): localhost:8000 (Debian/Ubuntu default)
#   - reverse-proxied behind Caddy/nginx: still the local Icecast — Caddy fronts the
#     signaling server, which in turn proxies /stream/* to ICECAST_HOST:ICECAST_PORT
#
# Mismatch → /stream/* returns 502 Bad Gateway.
ICECAST_HOST=localhost
ICECAST_PORT=6737
ICECAST_PASS=changeme

# JWT secret (Phase 2 - leave empty for auto-generation)
JWT_SECRET=

# Room TTL (milliseconds, 0 = no expiry, 900000 = 15 min for demo)
ROOM_TTL_MS=0

# Show-notes LLM (OpenAI-compatible API: LM Studio, Ollama OpenAI shim, vLLM, llama.cpp server, etc.)
# Optional — if unreachable, show-notes generation falls back to a simple transcript-derived summary.
# Default port 1234 matches LM Studio. Include the /v1 path.
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=qwen3.5-35b

# LLM API key — only needed for cloud providers like OpenAI, Anthropic, Together, Groq.
# Leave blank for local providers (LM Studio, Ollama, llama.cpp server, vLLM).
LLM_API_KEY=
